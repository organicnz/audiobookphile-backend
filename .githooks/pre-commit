#!/bin/bash

echo "Running Deno Lint on staged files..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.ts$")

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

if which deno >/dev/null; then
    for file in $STAGED_FILES; do
        deno lint "$file"
        if [ $? -ne 0 ]; then
            echo "❌ Deno Lint failed on $file. Please fix the errors before committing."
            exit 1
        fi
        deno fmt --check "$file"
        if [ $? -ne 0 ]; then
            echo "❌ Deno Fmt failed on $file. Please format before committing."
            exit 1
        fi
    done
else
    echo "⚠️ warning: Deno not installed."
fi

exit 0
