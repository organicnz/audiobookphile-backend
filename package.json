{
  "name": "audiobookphile-backend",
  "version": "1.0.0",
  "description": "Supabase backend for audiobookphile",
  "scripts": {
    "start": "supabase start",
    "stop": "supabase stop",
    "status": "supabase status",
    "deploy": "supabase link --project-ref <your-project-id> && supabase db push",
    "gen:types": "supabase gen types typescript --linked > ../audiobookphile-web/src/types/supabase.ts",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0"
  },
  "devDependencies": {
    "@evilmartians/lefthook": "^2.1.9",
    "supabase": "^2.98.2"
  }
}
